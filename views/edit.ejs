<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit Your Chat</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>
    <div class="container">
        <h3 class="page-title">Edit Your Chat</h3>
        <div class="form-container">
            <div class="chat-info">
                <p>This chat was sent from <b><%=chat.from%></b> to <b><%=chat.to%></b></p>
            </div>
            
            <form method="POST" action="/chats/<%=chat._id%>?_method=PUT">
                <div class="form-group">
                    <label for="msg">Message</label>
                    <textarea id="msg" name="msg" rows="6" required><%=chat.msg%></textarea>
                </div>
                
                <button type="submit" class="submit-btn">Update Chat</button>
            </form>
            
            <div style="text-align: center; margin-top: 20px;">
                <a href="/chats">
                    <button type="button" class="back-btn">← Back to All Chats</button>
                </a>
            </div>
        </div>
    </div>
</body>
</html>
