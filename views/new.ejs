<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Write New Chat</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>
    <div class="container">
        <h3 class="page-title">Write New Chat</h3>
        <div class="form-container">
            <form method="POST" action="/chats">
                <div class="form-group">
                    <label for="from">Your Name</label>
                    <input type="text" id="from" placeholder="Who are you?" name="from" required>
                </div>
                
                <div class="form-group">
                    <label for="msg">Your Message</label>
                    <textarea id="msg" name="msg" placeholder="Write your message here..." required></textarea>
                </div>
                
                <div class="form-group">
                    <label for="to">Receiver's Name</label>
                    <input type="text" id="to" placeholder="Add receiver" name="to" required>
                </div>
                
                <button type="submit" class="submit-btn">Create Chat</button>
            </form>
            
            <div style="text-align: center; margin-top: 20px;">
                <a href="/chats">
                    <button type="button" class="back-btn">← Back to All Chats</button>
                </a>
            </div>
        </div>
    </div>
</body>
</html>
